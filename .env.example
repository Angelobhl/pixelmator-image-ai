# Gemini Bridge Configuration
# Copy this file to .env and fill in your values

# API Configuration
GEMINI_BRIDGE_API_KEY=your_api_key_here
GEMINI_BRIDGE_DEFAULT_MODEL=google/gemini-3-pro-image-preview
GEMINI_BRIDGE_TEMPERATURE=0.7
GEMINI_BRIDGE_MAX_TOKENS=4096

# Image Processing Configuration
GEMINI_BRIDGE_MAX_IMAGE_SIZE=2048
GEMINI_BRIDGE_IMAGE_QUALITY=85

# UI Configuration
GEMINI_BRIDGE_WINDOW_OPACITY=0.9
GEMINI_BRIDGE_AUTO_HIDE=true
GEMINI_BRIDGE_SHOW_NOTIFICATION=true
GEMINI_BRIDGE_PLAY_SOUND=false

# Debug Mode
GEMINI_BRIDGE_DEBUG_MODE=false

# Paths (relative to project root)
GEMINI_BRIDGE_TEMP_DIR=./temp
GEMINI_BRIDGE_CACHE_DIR=./cache